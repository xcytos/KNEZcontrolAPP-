{
  "identifier": "default",
  "description": "Default capabilities for KNEZ Control App",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "fs:default",
    "http:default",
    "shell:allow-open",
    {
      "identifier": "shell:allow-spawn",
      "allow": [
        {
          "name": "start-local-stack",
          "cmd": "powershell.exe",
          "args": [
            "-ExecutionPolicy",
            "Bypass",
            "-File",
            "scripts/start_local_stack.ps1"
          ]
        },
        {
          "name": "exec",
          "cmd": "taskkill",
          "args": true
        }
      ]
    }
  ]
}